# Example dbt profile for LadingLens.
# Copy to ~/.dbt/profiles.yml and it will read credentials from environment
# variables (see .env.example at the project root) — never hardcode secrets here.

ladinglens:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE') }}"
      database: "{{ env_var('SNOWFLAKE_DATABASE', 'LADINGLENS_DB') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE', 'LADINGLENS_WH') }}"
      schema: "{{ env_var('SNOWFLAKE_SCHEMA', 'RAW') }}"
      threads: 4
